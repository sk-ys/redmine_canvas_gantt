<% project = local_assigns[:project] || @project %>
<% query = local_assigns[:query] || @query %>
<% can_open_canvas_gantt = project.present? && User.current.allowed_to?(:view_canvas_gantt, project) %>

<% if can_open_canvas_gantt %>
  <% canvas_gantt_url = ::RedmineCanvasGantt::QueryLinkHelper.canvas_gantt_query_action_url(
    base_path: project_canvas_gantt_path(project),
    query: query,
    request_query_parameters: request.query_parameters
  ) %>
  <script>
    (function() {
      var body = document.body;
      if (!body || !body.classList.contains('controller-issues') || !body.classList.contains('action-index')) return;

      var candidateSelectors = ['#main-menu a[href*="/canvas_gantt"]', '#project-menu a[href*="/canvas_gantt"]'];
      var menuLink = null;

      for (var i = 0; i < candidateSelectors.length && !menuLink; i += 1) {
        var candidate = document.querySelector(candidateSelectors[i]);
        if (!candidate) continue;

        try {
          var parsed = new URL(candidate.href, window.location.origin);
          if (parsed.pathname.indexOf('/canvas_gantt') === -1) continue;
          menuLink = candidate;
        } catch (error) {
          continue;
        }
      }

      if (!menuLink) return;

      try {
        var currentActionUrl = new URL("<%= j(canvas_gantt_url) %>", window.location.origin);
        var currentMenuUrl = new URL(menuLink.href, window.location.origin);
        currentMenuUrl.pathname = currentActionUrl.pathname;
        currentMenuUrl.search = currentActionUrl.search;
        menuLink.href = currentMenuUrl.toString();
      } catch (error) {
        menuLink.href = "<%= j(canvas_gantt_url) %>";
      }
    })();
  </script>
<% end %>
